---
import { Font } from "astro:assets"
import i18n from "i18next"

import "../styles/global.css"

import { SEO } from "astro-seo"
import { Schema } from "astro-seo-schema"
import type { Person, ProfilePage, Thing, WebSite, WithContext } from "schema-dts"

import { ClientRouter } from "astro:transitions"

import profilImage from "../assets/profil.webp"
import faviconSvg from "../assets/logo.svg?no-inline"

import PostHog from "../components/common/PostHog.astro"
import { ConsentBanner } from "../components/ConsentBanner"
import {
	getAbsoluteLocalizedUrl,
	getLocaleAlternates,
	languageTags,
	type Locale
} from "../i18n/config"

interface Props {
	locale: Locale
	pathname: string
	title?: string
	description?: string
	noindex?: boolean
	schema?: WithContext<Thing> | WithContext<Thing>[]
}

const { locale, pathname, title, description, noindex = false, schema } = Astro.props

const seoT = i18n.getFixedT(locale, "seo")
const resolvedDescription = description ?? seoT("defaultDescription")
const websiteUrl = "https://alex73630.xyz"
const languageTag = languageTags[locale]
const canonicalUrl = getAbsoluteLocalizedUrl(pathname, locale)
const alternates = getLocaleAlternates(pathname)

const personSchema: WithContext<Person> = {
	"@context": "https://schema.org",
	"@type": "Person",
	"@id": `${websiteUrl}/#person`,
	name: "Alexandre Sanchez",
	url: websiteUrl,
	jobTitle: seoT("jobTitle"),
	description: resolvedDescription,
	image: `${websiteUrl}${profilImage.src}`,
	worksFor: {
		"@type": "Organization",
		name: "Otterly Space"
	},
	sameAs: [
		"https://bsky.app/profile/alex73630.xyz",
		"https://twitter.com/alex73630",
		"https://github.com/alex73630",
		"https://www.linkedin.com/in/alex-otterly/"
	]
}

const profilePageSchema: WithContext<ProfilePage> = {
	"@context": "https://schema.org",
	"@type": "ProfilePage",
	"@id": `${canonicalUrl}#webpage`,
	url: canonicalUrl,
	name: title ? `${title} - Alexandre Sanchez` : "Alexandre Sanchez",
	description: resolvedDescription,
	mainEntity: {
		"@id": `${websiteUrl}/#person`
	}
}

const webSiteSchema: WithContext<WebSite> = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	"@id": `${websiteUrl}/#website`,
	url: websiteUrl,
	name: "Alexandre Sanchez",
	description: seoT("websiteDescription"),
	inLanguage: languageTag,
	publisher: {
		"@id": `${websiteUrl}/#person`
	}
}

const schemas = [
	personSchema,
	profilePageSchema,
	webSiteSchema,
	...(Array.isArray(schema) ? schema : schema ? [schema] : [])
]
---
<html lang={languageTag} class="not-motion-reduce:scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<Font cssVariable="--font-ibm-plex" preload />
		<SEO
			title={title}
			titleTemplate="%s - Alexandre Sanchez"
			titleDefault="Alexandre Sanchez"
			description={resolvedDescription}
			twitter={{
				creator: "@alex73630",
				card: "summary",
				title: title ? `${title} - Alexandre Sanchez` : "Alexandre Sanchez",
				description: resolvedDescription
			}}
			extend={{
				meta: [
					{ name: "generator", content: Astro.generator },
					{ name: "viewport", content: "width=device-width" },
					...(noindex ? [{ name: "robots", content: "noindex, nofollow" }] : [])
				],
				link: [
					{ rel: "canonical", href: canonicalUrl },
					{ rel: "alternate", hreflang: "fr", href: alternates.fr },
					{ rel: "alternate", hreflang: "en", href: alternates.en },
					{ rel: "alternate", hreflang: "x-default", href: alternates.fr },
					{ rel: "sitemap", href: "/sitemap-index.xml" }
				],
			}}
		/>

		<link href={faviconSvg} type="image/svg+xml" rel="icon" />

		{schemas.map((s) => <Schema item={s} />)}
		<ClientRouter />
		<PostHog />
	</head>
	<body class="bg-[#0b1120] text-slate-100 antialiased min-h-screen relative selection:bg-otter-pink-200 selection:text-[#0b1120]">
		{/* Global Gradient & SVG pattern wrapper */}
		<div class="absolute inset-0 pointer-events-none z-[-1] overflow-hidden">
			<svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg" class="absolute top-0 left-0 w-full h-screen opacity-30" aria-hidden="true" focusable="false">
				<rect x="0" y="0" width="100%" height="100%" fill="url(#grad)" opacity="1"/>
				<defs>
					<radialGradient id="grad" gradientUnits="userSpaceOnUse" cx="50%" cy="-20%" r="70%">
						<stop stop-color="rgba(249,169,213,0.15)" offset="0%"/>
						<stop stop-color="rgba(249,169,213,0)" offset="100%"/>
					</radialGradient>
				</defs>
			</svg>
		</div>
		<slot />
		<script>
				import twemoji from "@twemoji/api"

				function parseTwemoji() {
						twemoji.parse(document.body, {
								base: "",
								folder: "/_astro/twemoji",
								ext: ".svg"
						})
				}

				function updateUwuModeFromQuery(search: string) {
						if (typeof document === "undefined") return

						const params = new URLSearchParams(search || "")
						const value = params.get("uwu")
						const hasUwu = params.has("uwu")
						const root = document.documentElement

						if (
							hasUwu &&
							(value === "false" || value === "0" || value === "null")
						) {
							sessionStorage.removeItem("uwuMode")
								root.classList.remove("uwu-mode")
								return
						}

						if (hasUwu || sessionStorage.getItem("uwuMode") === "true") {
							if (hasUwu) sessionStorage.setItem("uwuMode", "true")
							root.classList.add("uwu-mode")
							return
						}

						if (value === null) {
							root.classList.remove("uwu-mode")
							return
						}

						const normalized = value.trim().toLowerCase()
						const enabled =
								normalized === "" ||
								normalized === "1" ||
								normalized === "true" ||
								normalized === "yes"

						if (
								normalized === "0" ||
								normalized === "false" ||
								normalized === "null" ||
								normalized === "no"
						) {
							sessionStorage.removeItem("uwuMode")
								root.classList.remove("uwu-mode")
								return
						}

						if (hasUwu) sessionStorage.setItem("uwuMode", "true")
						root.classList.toggle("uwu-mode", enabled)
				}

				parseTwemoji()
				document.addEventListener("astro:page-load", () => {
						parseTwemoji()
						if (typeof window !== "undefined") {
								updateUwuModeFromQuery(window.location.search)
						}
				})

				if (typeof window !== "undefined") {
						updateUwuModeFromQuery(window.location.search)
				}
		</script>
		<ConsentBanner client:only="react" locale={locale} />
	</body>
</html>
