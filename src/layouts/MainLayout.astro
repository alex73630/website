---
import '../styles/global.css'

import { SEO } from "astro-seo";

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
---
<html lang="fr">
	<head>
		<SEO
			title={title}
			titleTemplate='%s - Alexandre Sanchez'
			titleDefault='Alexandre Sanchez'
			description={description}
			charset='utf-8'
			twitter={{
				creator: "@alex73630",
				card: "summary",
				title: title ? `${title} - Alexandre Sanchez` : "Alexandre Sanchez",
				description: description
			}}
			extend={{
				meta: [{ name: "generator", content: Astro.generator }, { name: "viewport", content: "width=device-width" }],
				link: [{ rel: "icon", href: "/favicon.ico" }, { rel: "icon", type: "image/svg+xml", href: "/favicon.svg" }, { rel: "sitemap", href: "/sitemap-index.xml" }],
			}}
		/>
	</head>
	<body class="bg-[#0b1120] text-slate-100 antialiased min-h-screen relative selection:bg-otter-pink-200 selection:text-[#0b1120]">
		{/* Global Gradient & SVG pattern wrapper */}
		<div class="absolute inset-0 pointer-events-none z-[-1] overflow-hidden">
			<svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg" class="absolute top-0 left-0 w-full h-150 opacity-30">
				<rect x="0" y="0" width="100%" height="100%" fill="url(#grad)" opacity="1"/>
				<defs>
					<radialGradient id="grad" gradientUnits="userSpaceOnUse" cx="50%" cy="-20%" r="70%">
						<stop stop-color="rgba(249,169,213,0.15)" offset="0%"/>
						<stop stop-color="rgba(249,169,213,0)" offset="100%"/>
					</radialGradient>
				</defs>
			</svg>
		</div>
		<slot />
	</body>
</html>
