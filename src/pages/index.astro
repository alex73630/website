---
import { Picture, getImage } from "astro:assets";
import MainLayout from "../layouts/MainLayout.astro";
import { Header } from "../components/Header";
import { Hero } from "../components/Hero";
import { Expertise } from "../components/Expertise";
import { Experience } from "../components/Experience";
import { ContentSection } from "../components/ContentSection";
import { Footer } from "../components/Footer";

import profilImage from "../assets/profil.png";
import twitchClipAvif from "../assets/twitch_clip.avif";
import twitchClipFallback from "../assets/twitch_clip_fallback.png";

const fallbackImage = await getImage({
	src: twitchClipFallback,
	widths: [320, 640, twitchClipFallback.width],
	format: 'webp'
});

---

<MainLayout>
	<Header />
	<main>
		<Hero>
			<Picture 
				src={profilImage} 
				formats={['avif', 'webp']}
				alt="Alexandre Sanchez" 
				widths={[360, 480, 600, 800]}
				sizes="(max-width: 1024px) 100vw, 600px"
				class="h-full w-full object-cover opacity-70 mix-blend-overlay transition-opacity duration-500 group-hover:opacity-80"
				fetchpriority="high"
				loading="eager"
			/>
		</Hero>
		<Expertise />
		<Experience />
		<ContentSection>
			<picture>
				<source srcset={twitchClipAvif.src} type="image/avif" media="(prefers-reduced-motion: no-preference)" />
				<source 
					srcset={fallbackImage.srcSet.attribute}
					sizes="(max-width: 1024px) 100vw, 50vw"
					type="image/webp"
				/>
				<img 
					src={fallbackImage.src}
					{...fallbackImage.attributes}
					alt="Twitch Livestream Preview" 
					class="absolute inset-0 h-full w-full object-cover opacity-60 transition-opacity group-hover:opacity-80"
				/>
			</picture>
		</ContentSection>
	</main>
	<Footer />
</MainLayout>
