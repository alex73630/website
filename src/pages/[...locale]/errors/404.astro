---
import i18n from "i18next"

import { Footer } from "../../../components/Footer"
import { Header } from "../../../components/Header"
import { buildLocaleStaticPaths, getLocalizedHref, normalizeLocale } from "../../../i18n/config"
import MainLayout from "../../../layouts/MainLayout.astro"

export function getStaticPaths() {
	return buildLocaleStaticPaths()
}

const locale = normalizeLocale(Astro.params.locale)
const errorsT = i18n.getFixedT(locale, "errors")
const seoT = i18n.getFixedT(locale, "seo")
const homeHref = getLocalizedHref("/", locale)
---

<MainLayout
	locale={locale}
	pathname={Astro.url.pathname}
	title={seoT("errors.notFoundTitle")}
	description={seoT("errors.notFoundDescription")}
	noindex
>
	<Header currentPathname={Astro.url.pathname} />
	<main class="flex min-h-[70vh] flex-col items-center justify-center px-6 py-24 text-center">
		<div class="relative">
			<div class="pointer-events-none absolute -top-12 left-1/2 z-0 h-64 w-64 -translate-x-1/2 rounded-full bg-otter-pink-200/20 blur-[80px]"></div>
			<h1 class="relative z-10 bg-linear-to-br from-white to-slate-500 bg-clip-text text-9xl font-black tracking-tighter text-transparent drop-shadow-xl sm:text-[12rem]">
				404
			</h1>
		</div>

		<h2 class="mt-8 text-3xl font-bold tracking-tight text-white sm:text-4xl">
			{errorsT("notFound.title")}
		</h2>

		<p class="mt-6 max-w-xl text-lg leading-relaxed text-slate-400">
			{errorsT("notFound.description")}
		</p>

		<div class="mt-10 flex gap-4">
			<a
				href={homeHref}
				class="bg-otter-pink-200 hover:bg-otter-pink-300 focus-visible:ring-otter-pink-200 w-full rounded-3xl px-8 py-4 text-center text-lg font-bold text-[#0b1120] shadow-[0_20px_25px_-5px_rgba(249,169,213,0.25)] transition-colors focus-visible:ring-2 focus-visible:outline-none sm:w-auto"
			>
				{errorsT("notFound.cta")}
			</a>
		</div>
	</main>
	<Footer />
</MainLayout>
