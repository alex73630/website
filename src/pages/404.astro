---
import MainLayout from "../layouts/MainLayout.astro";
import { Header } from "../components/Header";
import { Footer } from "../components/Footer";
---

<MainLayout title="404 - Page non trouvée">
	<Header />
	<main class="flex min-h-[70vh] flex-col items-center justify-center px-6 py-24 text-center">
		<div class="relative">
			<!-- Decorative blurs -->
			<div class="pointer-events-none absolute -top-12 left-1/2 z-0 h-64 w-64 -translate-x-1/2 rounded-full bg-otter-pink-200/20 blur-[80px]"></div>
			
			<h1 class="relative z-10 text-9xl font-black tracking-tighter text-transparent bg-clip-text bg-linear-to-br from-white to-slate-500 drop-shadow-xl sm:text-[12rem]">
				404
			</h1>
		</div>
		
		<h2 class="mt-8 text-3xl font-bold tracking-tight text-white sm:text-4xl">
			Oups... Cette loutre s'est perdue en mer.
		</h2>
		
		<p class="mt-6 max-w-xl text-lg leading-relaxed text-slate-400">
			La page que tu recherches n'existe pas ou a été déplacée. Mais ne t'inquiète pas, tu peux toujours retourner en lieu sûr.
		</p>
		
		<div class="mt-10 flex gap-4">
			<a
				href="/"
				class="bg-otter-pink-200 hover:bg-otter-pink-300 focus-visible:ring-otter-pink-200 w-full rounded-3xl px-8 py-4 text-center text-lg font-bold text-[#0b1120] shadow-[0_20px_25px_-5px_rgba(249,169,213,0.25)] transition-colors focus-visible:ring-2 focus-visible:outline-none sm:w-auto"
			>
				Retour au bercail
			</a>
		</div>
	</main>
	<Footer />
</MainLayout>
